# ============================================================================
# PawMatch — Environment Variables Template
# ============================================================================
# Copy this file to `.env.local` and fill in real values for local development.
#
# RULES:
#   1. NEVER commit `.env.local` to git.
#   2. NEVER put real secrets in THIS file (.env.example) — placeholders only.
#   3. Production/preview values live in Vercel project settings, scoped to
#      the correct environment.
#   4. Any env var prefixed with NEXT_PUBLIC_ is exposed to the browser.
#      Treat anything without that prefix as server-only and private.
#
# This template covers ALL phases — you won't need most of these until the
# phase that introduces them. Lines below are grouped by phase.
# ============================================================================


# ----------------------------------------------------------------------------
# Core — needed from Phase 0
# ----------------------------------------------------------------------------

NODE_ENV=development

# The public URL of the site. Used for absolute URLs (OG tags, OAuth redirects,
# password reset emails, Stripe return URLs). Must match where the app is served.
#   Local:       http://localhost:3000
#   Preview:     the Vercel preview URL (set automatically by Vercel)
#   Production:  https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ----------------------------------------------------------------------------
# Supabase — needed from Phase 1
# Get these from: Supabase Dashboard → your project → Settings → API
# ----------------------------------------------------------------------------

# The project URL. Looks like https://abcdefg.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# The anonymous (public) key. Safe to expose to browsers — it relies on RLS
# policies in the database for security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# The service role key. BYPASSES ALL RLS. Server-only. Never prefix with
# NEXT_PUBLIC_. Never commit. Never log.
# Use only in trusted server contexts (e.g. webhook handlers, scheduled jobs).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-SERVER-ONLY>


# ----------------------------------------------------------------------------
# Stripe — needed from Phase 7
# Get these from: Stripe Dashboard → Developers → API keys
# Use TEST keys during development. Live keys (sk_live_...) only in production,
# only after explicit go-live approval.
# ----------------------------------------------------------------------------

# Secret key — server-only. Starts with sk_test_ in dev, sk_live_ in production.
STRIPE_SECRET_KEY=sk_test_<test-secret-key>

# Publishable key — safe for browsers. Starts with pk_test_ in dev, pk_live_ in prod.
# The NEXT_PUBLIC_ prefix is required to use this in client components.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<test-publishable-key>

# Webhook signing secret — different per environment. Starts with whsec_.
# How to obtain:
#   Local:       run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#                → copy the whsec_... the CLI prints
#   Preview/Prod: Stripe Dashboard → Developers → Webhooks → your endpoint →
#                "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_<signing-secret>

# Connect client ID — for OAuth-style Connect flows. Starts with ca_.
# Get from: Stripe Dashboard → Settings → Connect → OAuth settings
STRIPE_CONNECT_CLIENT_ID=ca_<connect-client-id>

# Platform commission in basis points (100 bps = 1%).
# 1500 = 15% platform fee. Adjust only after discussion.
PLATFORM_COMMISSION_BPS=1500


# ----------------------------------------------------------------------------
# Resend — needed from Phase 11
# Get from: https://resend.com/api-keys
# ----------------------------------------------------------------------------

RESEND_API_KEY=re_<your-api-key>

# The "from" address for transactional emails.
# Local/Preview: use onboarding@resend.dev (Resend's test sender, no domain
#                verification required).
# Production:    use noreply@yourdomain.com — requires completing domain
#                verification in Resend (SPF + DKIM DNS records).
EMAIL_FROM=onboarding@resend.dev

# Display name shown next to the from address in email clients.
EMAIL_FROM_NAME=PawMatch


# ----------------------------------------------------------------------------
# Sentry — needed from Phase 13
# Get from: Sentry project → Settings → Client Keys (DSN)
# ----------------------------------------------------------------------------

# DSN (Data Source Name) — the endpoint errors are reported to.
# Different DSN for preview vs production.
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>

# Organization and project slugs for source map upload (CI only).
SENTRY_ORG=<your-sentry-org-slug>
SENTRY_PROJECT=<your-sentry-project-slug>

# Auth token for source map uploads during build. CI only, never runtime.
# Get from: Sentry → Settings → Account → API → Auth Tokens
SENTRY_AUTH_TOKEN=<auth-token-for-source-map-upload>


# ----------------------------------------------------------------------------
# Cloudflare Turnstile — needed from Phase 13 (CAPTCHA on signup)
# Free. Get from: https://dash.cloudflare.com → Turnstile → Add site
# ----------------------------------------------------------------------------

NEXT_PUBLIC_TURNSTILE_SITE_KEY=<site-key>
TURNSTILE_SECRET_KEY=<secret-key>


# ----------------------------------------------------------------------------
# Upstash Redis — optional in Phase 13 (rate limiting)
# Free tier: 10k commands/day. Get from: https://console.upstash.com
# ----------------------------------------------------------------------------

UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<rest-token>


# ----------------------------------------------------------------------------
# Map tiles — Phase 5 (trainer search map view)
# MapLibre GL + OpenStreetMap is free. No env var needed for OSM tiles.
# If you migrate to Mapbox later (commercial limits on OSM), add:
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.<token>
# ----------------------------------------------------------------------------


# ----------------------------------------------------------------------------
# Feature flags — optional, grows over time
# ----------------------------------------------------------------------------

# Toggle major features on/off without redeploying. Defaults to enabled when
# the var is unset. Uncomment to explicitly control.
#
# FEATURE_MESSAGING_ENABLED=true
# FEATURE_REVIEWS_ENABLED=true
# FEATURE_ADMIN_DASHBOARD_ENABLED=true


# ----------------------------------------------------------------------------
# Local Supabase (set automatically by `supabase start` — do not hand-edit)
# ----------------------------------------------------------------------------
#
# When running `supabase start`, the CLI prints default local credentials.
# For local dev you can use these instead of the hosted dev project:
#   SUPABASE_URL_LOCAL=http://127.0.0.1:54321
#   SUPABASE_ANON_KEY_LOCAL=<provided-by-supabase-start>
#   SUPABASE_SERVICE_ROLE_KEY_LOCAL=<provided-by-supabase-start>
#
# These are safe-to-share local-only values — they don't apply to your remote
# project and aren't actually secret.
